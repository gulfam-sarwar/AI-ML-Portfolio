   ],
   "source": [
    "i = 10\n",
    "if (i == 10):\n",
    "    if (i < 15) :\n",
    "        print(\"i is smaller than 15\")\n",
    "    if (i < 12) :\n",
    "        print(\"i is smaller than 12 too\")\n",
    "else:\n",
    "    print(\"i is greater than 15\")"
   ]
