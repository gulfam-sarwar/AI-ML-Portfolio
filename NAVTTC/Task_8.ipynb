   "metadata": {},
   "source": [
    "## Print Area of Triangle"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "9fc4f34b-c152-443f-82b8-c186f656bd96",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter first side:  2\n",
      "Enter second side:  2\n",
      "Enter third side:  2\n"
     ]
    }
   ],
   "source": [
    "a = float(input(\"Enter first side: \"))\n",
    "b = float(input(\"Enter second side: \"))\n",
    "c = float(input(\"Enter third side: \"))\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "a6a30cf0-1cce-4c25-9f7f-94d7c035d90d",
   "metadata": {},
   "outputs": [],
   "source": [
    "s = (a+b+c)/2"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "a65ac1e1-7594-4aa4-8eb6-378bb838d4b2",
   "metadata": {},
   "outputs": [],
   "source": [
    "area = (s*(s-a)*(s-b)*(s-c))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "376d3545-cba9-44bb-9587-76c73050598c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "The area of triangle is 3.00 \n"
     ]
    }
   ],
   "source": [
    "print(\"The area of triangle is %0.2f \" %area)"
   ]
  },
